{
   "compilerOptions": {
      "lib": [
         "es2023"
      ],
      "target": "es2022",
      "module": "commonjs",
      "moduleResolution": "node",
      "outDir": "./build",
      "emitDecoratorMetadata": true,
      "experimentalDecorators": true,
      "sourceMap": true,
      "baseUrl": "./",
      "paths": {
         "@entities/*": ["src/entities/*"],
         "*": ["src/*"]
      },
      "types": ["node"]
   }
}